{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-shared-memory/schemas/absorption-plan.schema.json",
  "title": "Shared-memory absorption plan",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "trigger",
    "pressure",
    "actions"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "trigger": {
      "type": "string"
    },
    "pressure": {
      "type": "object",
      "required": [
        "triggered",
        "reasons",
        "thresholds",
        "metrics"
      ],
      "properties": {
        "triggered": {
          "type": "boolean"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "thresholds": {
          "type": "object"
        },
        "metrics": {
          "type": "object"
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidatePath",
          "action",
          "reason",
          "evidence",
          "confidence",
          "safeToApply"
        ],
        "properties": {
          "candidatePath": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "pattern": "^(retain_memory|move_scope|promote_to_[a-z][a-z0-9_-]*|deprecate|keep_inbox|merge_into_existing)$"
          },
          "mergeInto": {
            "type": "string",
            "description": "Target curated entry path (required when action is merge_into_existing)"
          },
          "mergeStrategy": {
            "type": "string",
            "enum": [
              "append_evidence",
              "update_body",
              "replace"
            ],
            "description": "Merge strategy (required when action is merge_into_existing). append_evidence: add new evidence to target's Evidence section. update_body: append candidate body as Additional Context section. replace: replace target entirely."
          },
          "reason": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "destination": {
            "type": [
              "string",
              "null"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "safeToApply": {
            "type": "boolean"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
