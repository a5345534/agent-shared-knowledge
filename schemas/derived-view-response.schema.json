{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "derived-view-response.schema.json",
  "type": "object",
  "required": ["pages"],
  "properties": {
    "pages": { "type": "array", "items": { "type": "object", "required": ["path", "title", "body"], "properties": {
      "path": { "type": "string", "pattern": "^[^/].*\\.md$" }, "title": { "type": "string", "minLength": 1 },
      "body": { "type": "string", "minLength": 1 }, "evidence": { "type": "array", "items": { "type": "string" } }
    }, "additionalProperties": false } },
    "gaps": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": false
}
